# ============================================================
# WISHING LAKE OF SMILES - Server Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wishing_lake?retryWrites=true&w=majority

# JWT Secrets - generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email (Nodemailer / Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Wishing Lake ✨ <noreply@wishinglake.com>"

# OpenAI for Wish Oracle AI Feature
OPENAI_API_KEY=sk-your-openai-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin Seed (first-run admin creation)
ADMIN_EMAIL=admin@wishinglake.com
ADMIN_PASSWORD=Admin@SecurePass123
